   "source": [
    "import matplotlib.pyplot as plt \n",
    "import numpy as np \n",
    "# line chart\n",
    "x = np.linspace(0,10,100)\n",
    "y = np.sin(x)\n",
    "plt.plot(x,y,color = \"red\")\n",
    "plt.subplot(2,3,1)\n",
    "plt.xlabel(\"X axis\")\n",
    "plt.ylabel(\"Y axis\")\n",
    "plt.title('Line chart')\n",
    "plt.show()\n"
   ]
  },
